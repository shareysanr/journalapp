# PostgreSQL (Neon). Use sslmode=require for hosted databases.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# AWS Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (optional — weekly reports fall back to template text if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS: Netlify frontend URL in production
FRONTEND_URL=http://localhost:5173

# Server port (Render sets PORT automatically)
PORT=3000

# Cron timezone for weekly report job (server local time)
TZ=America/Los_Angeles
