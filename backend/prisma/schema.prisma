generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

model Entry {
  id                 Int      @id @default(autoincrement())
  userId             String   @map("user_id")
  date               DateTime @db.Date
  goalsPlanned       String   @map("goals_planned")
  numGoals           Int      @map("num_goals")
  goalsCompleted     Int      @map("goals_completed")
  distractions       String[]
  negativeComponents String[] @map("negative_components")
  positiveComponents String[] @map("positive_components")
  difficulty         Int
  rating             Int
  notes              String?

  @@map("entries")
}

model WeeklyReport {
  id                       Int      @id @default(autoincrement())
  userId                   String   @map("user_id")
  weekStartDate            DateTime @db.Date @map("week_start_date")
  weekEndDate              DateTime @db.Date @map("week_end_date")
  summary                  String
  recommendations          String
  accomplishments          Int
  failures                 Int
  averageRating            Float    @map("average_rating")
  commonDistractions       String[] @map("common_distractions")
  commonNegativeComponents String[] @map("common_negative_components")
  commonPositiveComponents String[] @map("common_positive_components")
  entryIds                 Int[]    @map("entry_ids")
  createdAt                DateTime @default(now()) @map("created_at")

  @@unique([userId, weekStartDate, weekEndDate])
  @@map("weekly_reports")
}
